# Render API local environment template.
# Copy to server/.env for local development. Add the same values in Render.

PORT=5000
PUBLIC_SITE_URL=http://localhost:5000
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://127.0.0.1:5000

# Supabase
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Email notifications via Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=Royal Braids <bookings@yourdomain.com>
CONTACT_NOTIFICATION_EMAIL=

# Cloudinary signed uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=royal-braids/gallery