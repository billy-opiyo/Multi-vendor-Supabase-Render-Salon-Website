{
	"name": "salon-render-backend",
	"version": "1.0.0",
	"description": "Render backend API foundation for the Supabase/Vercel salon rebuild.",
	"main": "src/server.js",
	"scripts": {
		"dev": "node --watch src/server.js",
		"start": "node src/server.js",
		"job": "node src/jobs/runJob.js",
		"job:notifications": "node src/jobs/runJob.js flushNotificationOutbox",
		"job:reminders": "node src/jobs/runJob.js sendUpcomingBookingReminders",
		"job:release-expired-slots": "node src/jobs/runJob.js releaseExpiredBookingSlots",
		"job:waitlist-slot-open": "node src/jobs/runJob.js syncWaitlistSlotOpenNotifications",
		"test": "vitest run"
	},
	"keywords": [
		"supabase",
		"render",
		"salon"
	],
	"author": "",
	"license": "ISC",
	"type": "commonjs",
	"dependencies": {
		"@supabase/supabase-js": "^2.107.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"helmet": "^8.2.0",
		"morgan": "^1.11.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"supertest": "^7.2.2",
		"vitest": "^4.1.8"
	}
}
