NODE_ENV=development

# Local development port. Render injects PORT automatically in production.
PORT=4000

# Supabase public project URL, for example: https://your-project-ref.supabase.co
SUPABASE_URL=

# Server-only service role key. Never expose this in browser/Vercel public code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional anon key for workflows that need public Supabase context server-side.
SUPABASE_ANON_KEY=

# Comma-separated list of allowed frontend origins for CORS.
# Examples:
# FRONTEND_ORIGIN=http://localhost:3000,https://your-site.vercel.app,https://your-custom-domain.com
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Phase 5 notification provider settings. Leave NOTIFICATION_DRY_RUN=true locally
# to queue and process notifications without calling external providers.
NOTIFICATION_DRY_RUN=true

# Resend email provider. Server-only values for Render.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# WhatsApp Cloud API provider. Server-only values for Render.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v21.0

# Optional shared secret for protected job endpoints/scripts if enabled.
JOB_SECRET=

# Scheduled job tuning.
UPCOMING_REMINDER_WINDOW_MINUTES=1440
EXPIRED_SLOT_GRACE_MINUTES=60